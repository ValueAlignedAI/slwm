{
  "runtime": {
    "seed": 70002,
    "deterministic": true,
    "device": "auto",
    "precision": "bf16"
  },
  "model": {
    "name": "slwm-t2-700m-audio-visual-24gb-fitcheck",
    "variant": "slwm_audio_visual_latent_700m_fitcheck",
    "parameter_accounting_mode": "strict",
    "target_parameter_count_notes": "~700M+ T2 scaling config intended for a single 24GB VRAM GPU only with bf16/fp16, activation checkpointing, batch_size=1, and gradient accumulation. Use --describe-only first; do not compare directly to SLWM-124M claims.",
    "context_length": 1024,
    "latent_length": 1024,
    "latent_dim": 1536,
    "n_layer": 19,
    "n_head": 16,
    "dropout": 0.0,
    "audio_feature_dim": 80,
    "visual_feature_dim": 256,
    "activation_checkpointing": true,
    "architecture_flags": {
      "use_local_temporal_mixer": true,
      "use_spectral_mixer": true,
      "use_long_conv": true,
      "use_attention_binding": true,
      "use_gated_mlp": true,
      "local_kernel_size": 3,
      "spectral_kernel_size": 31,
      "long_kernel_size": 31,
      "mlp_ratio": 4,
      "policy_commit_gate": false,
      "noop_head": false,
      "activation_checkpointing": true
    },
    "memory_saving": {
      "activation_checkpointing": true,
      "recommended_precision": "bf16_or_fp16",
      "recommended_optimizer": "adamw_torch; switch to 8-bit optimizer only in a separately documented dependency environment",
      "recommended_batch_size": 1,
      "recommended_gradient_accumulation_steps": 32,
      "expected_fit": "Best-effort 24GB VRAM fit-check; not guaranteed across frameworks/devices."
    }
  },
  "data": {
    "modalities": [
      "audio",
      "visual_video"
    ],
    "prepared_corpus_dir": "artifacts/t2_audio_visual/vggsound_20k_logmel_vit_v0",
    "sample_schema_version": "t2.audio_visual_latents_v0",
    "audio_codec_or_features": "frozen_log_mel_80bin_16khz",
    "visual_codec_or_features": "frozen_vit_or_dino_frame_patch_latents_fp16",
    "feature_spec": {
      "audio_feature_dim": 80,
      "visual_feature_dim": 256,
      "audio_length": 512,
      "visual_length": 512
    },
    "dataset_mix": {
      "text_code": null,
      "audio": 0.5,
      "visual_video": 0.5
    },
    "dataset_plan": {
      "primary_paired_av": "VGGSound local subset: 20000 train / 2000 validation / 2000 test clips after availability filtering",
      "audio_controls": "LibriSpeech train-clean-100 and FSD50K 10k subset as separate audio-only robustness corpora",
      "license_and_access": "Record raw source licenses, dead clip rate, feature extractor hash, and split hashes before evidence-bearing runs"
    }
  },
  "training": {
    "objective": [
      "audio_latent_continuation_mse",
      "visual_latent_continuation_mse",
      "missing_span_reconstruction_mse",
      "audio_video_contrastive_alignment"
    ],
    "optimizer": "adamw_torch",
    "learning_rate_schedule": "cosine",
    "learning_rate": 0.00015,
    "weight_decay": 0.05,
    "batch_size": 1,
    "gradient_accumulation_steps": 32,
    "steps": 10000,
    "validation_batches": 8,
    "context_fraction": 0.5,
    "missing_span_fraction": 0.15,
    "grad_clip_norm": 1.0,
    "loss_weights": {
      "audio_prediction": 1.0,
      "visual_prediction": 1.0,
      "alignment": 0.1
    },
    "claim_scope": "T2 scaling/fit-check only; not a 124M comparison"
  },
  "registry": {
    "experiment_id": "EXP-T2-701",
