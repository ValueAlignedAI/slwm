{
  "runtime": {
    "seed": 12402,
    "deterministic": true,
    "device": "auto",
    "precision": "bf16"
  },
  "model": {
    "name": "slwm-t2-124m-audio-visual-latent-pilot",
    "variant": "slwm_audio_visual_latent",
    "parameter_accounting_mode": "strict",
    "target_parameter_count_notes": "GPT-2-scale T2 latent model; estimate is near 124M without text-token embeddings because T2 is audio/visual latent only.",
    "context_length": 1024,
    "latent_length": 1024,
    "latent_dim": 768,
    "n_layer": 13,
    "n_head": 12,
    "dropout": 0.0,
    "audio_feature_dim": 80,
    "visual_feature_dim": 256,
    "activation_checkpointing": true,
    "architecture_flags": {
      "use_local_temporal_mixer": true,
      "use_spectral_mixer": true,
      "use_long_conv": true,
      "use_attention_binding": true,
      "use_gated_mlp": true,
      "local_kernel_size": 3,
      "spectral_kernel_size": 31,
      "long_kernel_size": 31,
      "mlp_ratio": 4,
      "policy_commit_gate": false,
      "noop_head": false,
      "activation_checkpointing": true
    }
  },
  "data": {
    "modalities": [
      "audio",
      "visual_video"
    ],
    "prepared_corpus_dir": "artifacts/t2_audio_visual/vggsound_5k_logmel_vit_v0",
    "sample_schema_version": "t2.audio_visual_latents_v0",
    "audio_codec_or_features": "frozen_log_mel_80bin_16khz",
    "visual_codec_or_features": "frozen_vit_or_dino_frame_patch_latents_fp16",
    "feature_spec": {
      "audio_feature_dim": 80,
      "visual_feature_dim": 256,
      "audio_length": 512,
      "visual_length": 512
    },
    "dataset_mix": {
      "text_code": null,
      "audio": 0.5,
      "visual_video": 0.5
    },
    "dataset_plan": {
      "primary_paired_av": "VGGSound local subset: 5000 train / 500 validation / 500 test clips after availability filtering",
      "audio_controls": "LibriSpeech train-clean-100 and/or FSD50K 10k subset prepared as separate T2 corpora",
      "license_and_access": "Record raw source licenses and unavailable media in dataset_card.json before evidence-bearing runs"
    }
  },
  "training": {
    "objective": [
      "audio_latent_continuation_mse",
      "visual_latent_continuation_mse",
      "missing_span_reconstruction_mse",
      "audio_video_contrastive_alignment"
    ],
    "optimizer": "adamw_torch",
    "learning_rate_schedule": "cosine",
    "learning_rate": 0.0003,
    "weight_decay": 0.05,
    "batch_size": 1,
    "gradient_accumulation_steps": 16,
    "steps": 10000,
    "validation_batches": 16,
    "context_fraction": 0.5,
    "missing_span_fraction": 0.15,
    "grad_clip_norm": 1.0,
    "loss_weights": {
      "audio_prediction": 1.0,
      "visual_prediction": 1.0,
      "alignment": 0.1
    },
    "claim_scope": "T2 124M-scale pilot only; no converged multimodal claim without registered baselines/ablations"
  },
  "registry": {
    "experiment_id": "EXP-T2-101",
    "artifact_dir": "experiments/multimodal/t2/EXP-T2-101",
    "path": "experiments/multimodal/t2/EXP-T2-101/registry.json",
    "metrics_path": "experiments/multimodal/t2/EXP-T2-101/metrics.json",
    "report_path": "experiments/multimodal/t2/EXP-T2-101/report.md",
    "checkpoint_path": "experiments/multimodal/t2/EXP-T2-101/checkpoint.pt",
    "config_copy_path": "experiments/multimodal/t2/EXP-T2-101/config.json"
  }
}
